// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  password       String?
  fullName       String?
  role           String         @default("customer") // admin, delivery, customer, cashier, cleaner, supervisor
  phone          String         @unique
  isActive       Boolean        @default(true)
  lastActive     DateTime       @default(now())
  isOnline       Boolean        @default(false)
  lastLoginAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  customer       Customer?
  driverTasks    DeliveryTask[] @relation("DriverTasks")
  recordedOrders Order[]        @relation("RecordedOrders")

  @@map("users")
}

model Customer {
  id                 String   @id @default(cuid())
  name               String
  phone              String?  @unique
  address            String?
  gender             String? // male, female, other
  type               String   @default("regular") // regular, walk-in
  loyaltyPoints      Int      @default(0)
  discountPercentage Float    @default(0)
  orders             Order[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  userId             String?  @unique
  user               User?    @relation(fields: [userId], references: [id])

  @@map("customers")
}

model Service {
  id          String        @id @default(cuid())
  name        String
  type        String // washing, dry_cleaning, ironing, folding, stain_removal
  basePrice   Float
  description String?
  isActive    Boolean       @default(true)
  items       ServiceItem[]
  orderItems  OrderItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("services")
}

model ServiceItem {
  id          String   @id @default(cuid())
  name        String
  price       Float
  description String?
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("service_items")
}

model Order {
  id               String        @id @default(cuid())
  orderNumber      String        @unique
  customerId       String?
  customer         Customer?     @relation(fields: [customerId], references: [id])
  status           String        @default("received") // received, accepted, in_process, ready, delivered, cancelled
  totalAmount      Float
  paidAmount       Float         @default(0)
  deliveryFee      Float         @default(0)
  discountAmount   Float         @default(0)
  notes            String?
  clothesTaken     Boolean       @default(false)
  expectedPickupAt DateTime? // Expected time the client will pick up the clothes
  receivedAt       DateTime?
  readyAt          DateTime?
  deliveredAt      DateTime?
  recordedBy       String? // Employee name who created the order (legacy)
  recordedById     String?
  recordedByUser   User?         @relation("RecordedOrders", fields: [recordedById], references: [id])
  items            OrderItem[]
  payments         Payment[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deliveryTask     DeliveryTask?

  @@map("orders")
}

model OrderItem {
  id                   String   @id @default(cuid())
  orderId              String
  order                Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceId            String?
  service              Service? @relation(fields: [serviceId], references: [id])
  itemName             String
  quantity             Int      @default(1)
  unitPrice            Float
  totalPrice           Float
  preCleaningPhotoUrl  String?
  postCleaningPhotoUrl String?
  barcode              String?
  qrCode               String?
  notes                String?
  createdAt            DateTime @default(now())

  @@map("order_items")
}

model Payment {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount        Float
  method        String // cash, mobile_money
  status        String   @default("pending") // pending, completed, failed, refunded
  transactionId String?
  notes         String?
  createdAt     DateTime @default(now())

  @@map("payments")
}

model DeliveryTask {
  id            String    @id @default(cuid())
  orderId       String    @unique
  order         Order     @relation(fields: [orderId], references: [id])
  assignedTo    String?
  assigned_user User?     @relation("DriverTasks", fields: [assignedTo], references: [id])
  type          String // pickup, delivery
  address       String?
  phone         String?
  status        String    @default("pending") // pending, in_transit, completed, cancelled
  scheduledAt   DateTime?
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("delivery_tasks")
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  category    String? // e.g., Electricity, Rent, Detergents, Water, Salaries, Fuel, Others
  date        DateTime @default(now())
  recordedBy  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
}
