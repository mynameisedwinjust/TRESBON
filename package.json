{
  "name": "imesero",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next node_modules/.cache .turbo",
    "clean:win": "powershell -Command \"Remove-Item -Recurse -Force .next -ErrorAction SilentlyContinue; Remove-Item -Recurse -Force node_modules/.cache -ErrorAction SilentlyContinue; Remove-Item -Recurse -Force .turbo -ErrorAction SilentlyContinue\"",
    "rebuild": "npm run clean && npm run build",
    "rebuild:win": "npm run clean:win && npm run build",
    "dev": "next dev",
    "build": "next build",
    "build:clean": "node scripts/clean-build.js && next build",
    "start": "next start",
    "lint": "next lint",
    "migrate": "node scripts/migrate-to-mongodb.js",
    "test-mongodb": "node setup-mongodb.js"
  },
